---
import { getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import LanguageNotice from "@/components/LanguageNotice.astro";
import { parsePostId } from "@/i18n";

const locale = 'zh-CN';

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  
  // 为每个 baseId 生成一个中文路由
  // 如果有中文版本，使用中文版本；如果没有，显示英文版本作为回退
  const baseIds = new Set<string>();
  allPosts.forEach((post) => {
    const { baseId } = parsePostId(post.id);
    baseIds.add(baseId);
  });
  
  return Array.from(baseIds).map((baseId) => ({
    params: { id: baseId },
    props: { baseId, allPosts },
  }));
}

const { baseId, allPosts } = Astro.props;

// 查找中文版本和英文版本
const zhPost = allPosts.find((post: any) => {
  const { baseId: postBaseId, locale: postLocale } = parsePostId(post.id);
  return postBaseId === baseId && postLocale === 'zh-CN';
});
const enPost = allPosts.find((post: any) => {
  const { baseId: postBaseId, locale: postLocale } = parsePostId(post.id);
  return postBaseId === baseId && postLocale === 'en';
});

// 优先显示中文版本，如果没有则显示英文版本
const post = zhPost || enPost;
const hasAlternate = !!zhPost && !!enPost;
const showingOriginal = !zhPost && !!enPost;

const displayPost = post!;
const alternateUrl = `/en/posts/${baseId}`;

const { Content, headings } = await render(post!);
---

<PostLayout frontmatter={displayPost.data} headings={headings} locale={locale}>
  {(hasAlternate || showingOriginal) && (
    <LanguageNotice
      locale={locale}
      hasAlternate={hasAlternate}
      alternateUrl={alternateUrl}
      alternateLocale="en"
      showingFallback={showingOriginal}
    />
  )}
  <Content />
</PostLayout>
